# Konstruktor bot token (@BotFather dan olinadi)
BOT_TOKEN=your_constructor_bot_token_here

# Konstruktor bot admin ID (sizning Telegram ID ingiz)
ADMIN_ID=your_telegram_id_here

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/constructor_bot

# Webhook
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PORT=8000

# Sozlamalar
TRIAL_DAYS=7
DAILY_PRICE=3000
REFERRAL_BONUS=5000
PAYMENT_CARD=your_card_number_here
